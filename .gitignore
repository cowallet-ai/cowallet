# Rust
/target/
**/*.rs.bk
# NOTE: Cargo.lock IS committed — this workspace ships binaries (api-server,
# worker, mpc-relay), so the lockfile is tracked for reproducible builds.

# Flutter / Dart
mobile/.dart_tool/
mobile/.packages
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/android/.gradle/
mobile/android/local.properties
mobile/*.iml

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment
.env
.env.*
!.env.example

# Secrets — never commit
*.pem
*.key
*.p12
*.jks

# Firebase config files (use .example templates instead)
mobile/ios/Runner/GoogleService-Info.plist
mobile/android/app/google-services.json

# Build artifacts
*.so
*.dylib
*.dll

# Compiled Rust→iOS FFI framework (regenerated by scripts/build_ios.sh)
mobile/ios/Frameworks/

# Next.js build output & cache (website)
website/.next/
website/out/
website/node_modules/

# Database
*.db
*.sqlite

# Logs
*.log

# OMC Agent state — per-run session/scratch artifacts should never be tracked.
# project-memory.json is intentional project config, so it is kept.
.omc/
!.omc/project-memory.json

# Stray Windows pub cache accidentally committed as a literal path
# (from `flutter pub get` on Windows writing to D:\PUB\...)
mobile/D:/

# Claude Code: keep committable playbooks (.claude/commands), ignore transient worktrees.
.claude/worktrees/
.pub-cache/
.dart_tool/

# Generated files
*.generated.*
mobile/ios/Runner/Runner 2026-05-18 15-43-49/

website/node_modules
website/.next
website/out