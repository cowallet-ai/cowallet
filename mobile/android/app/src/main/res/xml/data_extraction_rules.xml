<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude all app data from cloud backup and device-to-device transfer.
     Shard ciphertext and encrypted preferences must never leave the device
     via ADB backup, Auto Backup, or D2D transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
