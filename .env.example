# ============================================================================
# cowallet Docker 部署 — 环境变量配置
# ============================================================================
# 复制此文件为 .env 并填入实际值

# ────────────────────────────────────────────────────────────────────────────
# 数据库
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cowallet

# ────────────────────────────────────────────────────────────────────────────
# 区块链 RPC（默认以太坊主网，各链独立配置见下方）
# ────────────────────────────────────────────────────────────────────────────
RPC_URL=https://1rpc.io/eth
RPC_WS_URL=wss://1rpc.io/eth

# ────────────────────────────────────────────────────────────────────────────
# 主网 RPC 端点（可选，覆盖默认公共节点）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
ETH_MAINNET_RPC_URL=
# Base Mainnet
BASE_MAINNET_RPC_URL=
# Arbitrum One
ARB_MAINNET_RPC_URL=
# Optimism Mainnet
OP_MAINNET_RPC_URL=
# BSC Mainnet
BSC_MAINNET_RPC_URL=
# Polygon Mainnet
POLYGON_MAINNET_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# OKX Web3 Wallet API (Onchain OS) — 多链资产/交易查询
# ────────────────────────────────────────────────────────────────────────────
# 从 https://web3.okx.com 开发者后台创建 API（前 3 项必填，否则余额/交易历史接口返回 503）
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# 可选：仅部分 project-scoped WaaS 接口需要
OKX_PROJECT_ID=

# ────────────────────────────────────────────────────────────────────────────
# Bridgers Cross-Chain Swap API — 代币兑换 (Swap)
# ────────────────────────────────────────────────────────────────────────────
# 与 Bridgers 协商获得的平台标识符（必填）
BRIDGERS_SOURCE_FLAG=

# ────────────────────────────────────────────────────────────────────────────
# 测试网 RPC 端点（可选）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Sepolia
ETH_SEPOLIA_RPC_URL=
# Base Sepolia
BASE_SEPOLIA_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# ERC-4337 Bundler 端点（账户抽象）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
BUNDLER_URL_ETH=
# Base Mainnet
BUNDLER_URL_BASE=
# Arbitrum One
BUNDLER_URL_ARB=
# Optimism Mainnet
BUNDLER_URL_OP=
# BSC Mainnet
BUNDLER_URL_BSC=
# Ethereum Sepolia
BUNDLER_URL_ETH_SEPOLIA=
# Base Sepolia
BUNDLER_URL_BASE_SEPOLIA=

# ────────────────────────────────────────────────────────────────────────────
# NATS 消息队列
# ────────────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ────────────────────────────────────────────────────────────────────────────
# Redis 缓存
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ────────────────────────────────────────────────────────────────────────────
# AI Provider 选择
# ────────────────────────────────────────────────────────────────────────────
# 显式指定生效的 AI provider,取值 bedrock | deepseek(大小写不敏感)。
# 缺省或非法值时回落到默认(bedrock)。
# AI chat 属只读/辅助路径,选择为 fail-open:若选定的 provider 未配置,
# 自动回退到另一个可用 provider(并打 warn 日志);两者都未配置时接口返回 503。
AI_PROVIDER=bedrock

# ────────────────────────────────────────────────────────────────────────────
# DeepSeek AI API
# ────────────────────────────────────────────────────────────────────────────
# 从 https://platform.deepseek.com 获取 API KEY
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# 可选：自定义 base URL（默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：模型名称（默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-v4-flash

# ────────────────────────────────────────────────────────────────────────────
# AWS Bedrock (Claude) — AI_PROVIDER=bedrock 时生效的引擎
# ────────────────────────────────────────────────────────────────────────────
# 未设置 BEDROCK_API_KEY 时该 provider 不初始化;若 AI_PROVIDER=bedrock 但此处
# 未配置,请求会 fail-open 回退到 DeepSeek。
BEDROCK_API_KEY=
# 可选：区域（默认 us-west-2）
BEDROCK_REGION=us-west-2
# 可选：模型 ID（默认 anthropic.claude-sonnet-4-20250514-v1:0）
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (FCM) — 推送通知
# ────────────────────────────────────────────────────────────────────────────
# FCM HTTP v1 API（legacy server key 已于 2024-06 被 Google 停用）。
# 从 Firebase Console > 项目设置 > 服务账号 > 生成新私钥 下载 service account JSON，
# 将其路径填在这里。project_id 从该 JSON 内读取，无需单独配置。
# 未设置时回退到标准变量 GOOGLE_APPLICATION_CREDENTIALS。
FCM_SERVICE_ACCOUNT_PATH=/path/to/cowallet-prod-firebase-adminsdk.json

# ────────────────────────────────────────────────────────────────────────────
# CORS 跨域配置
# ────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ────────────────────────────────────────────────────────────────────────────
# JWT 认证密钥
# ────────────────────────────────────────────────────────────────────────────
# 用于签发和验证用户登录令牌
# 生成强密钥：openssl rand -base64 32
# ⚠️  生产环境务必使用强密钥（最少 32 字符）
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# ────────────────────────────────────────────────────────────────────────────
# MPC 消息 HMAC 密钥（独立于 JWT_SECRET）
# ────────────────────────────────────────────────────────────────────────────
# 用于校验发往服务器参与方(Party 1)的 MPC 协议消息完整性
# 生成强密钥：openssl rand -base64 32
# ⚠️  必须独立于 JWT_SECRET；生产环境务必使用强密钥（最少 32 字符）
MPC_HMAC_KEY=change_me_independent_32_byte_min_hmac_key

# ────────────────────────────────────────────────────────────────────────────
# 分片加密密钥（32 字节 hex，用于加密 MPC 密钥分片）
# ────────────────────────────────────────────────────────────────────────────
# 生成：openssl rand -hex 32
# ⚠️  生产环境务必使用随机生成的密钥
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ────────────────────────────────────────────────────────────────────────────
# 运行环境
# ────────────────────────────────────────────────────────────────────────────
# 设为 production 时启用生产安全策略(例如未配置 TURNSTILE_SECRET_KEY 时
# 人机验证将 fail-closed 拒绝而非跳过)。本地/测试留空即可。
APP_ENV=

# ────────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile 人机验证
# ────────────────────────────────────────────────────────────────────────────
# 未配置时:非生产环境跳过校验;生产环境(APP_ENV=production)直接拒绝。
TURNSTILE_SECRET_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 日志级别
# ────────────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ────────────────────────────────────────────────────────────────────────────
# PostgreSQL 初始化密码（仅 Docker 第一次运行）
# ⚠️  生产环境务必修改为强密码
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=cowallet

# ────────────────────────────────────────────────────────────────────────────
# 强制升级门槛（客户端 + 服务端双层校验）
# ────────────────────────────────────────────────────────────────────────────
# 客户端启动时读 /api/v1/config/app-version 自检;服务端对受保护路由校验
# X-App-Version header,低于 MIN_APP_BUILD 直接返回 426。
# build 号 = pubspec version 中 "+" 后的整数(如 1.0.1+17 → 17)。
#
# ⚠️  MIN_APP_BUILD=0 表示 fail-open(不拦任何人)。务必等新版本在双端商店
#     上架可下载后,再把它拉高到新 build,否则老用户会被锁在升级墙外且无版本可下。
# 回滚:出问题先把 MIN_APP_BUILD=0 重启,秒级解除全体拦截。
MIN_APP_BUILD=0
LATEST_APP_BUILD=0
# iOS 需真实数字 App Store ID:https://apps.apple.com/app/id<数字ID>
IOS_STORE_URL=
ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.cowallet.app
