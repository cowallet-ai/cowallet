# ============================================================================
# cowallet Docker 部署 — 环境变量配置
# ============================================================================
# 复制此文件为 .env 并填入实际值

# ────────────────────────────────────────────────────────────────────────────
# 数据库
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cowallet

# ────────────────────────────────────────────────────────────────────────────
# 区块链 RPC（默认以太坊主网，各链独立配置见下方）
# ────────────────────────────────────────────────────────────────────────────
RPC_URL=https://1rpc.io/eth
RPC_WS_URL=wss://1rpc.io/eth

# ────────────────────────────────────────────────────────────────────────────
# 主网 RPC 端点（可选，覆盖默认公共节点）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
ETH_MAINNET_RPC_URL=
# Base Mainnet
BASE_MAINNET_RPC_URL=
# Arbitrum One
ARB_MAINNET_RPC_URL=
# Optimism Mainnet
OP_MAINNET_RPC_URL=
# BSC Mainnet
BSC_MAINNET_RPC_URL=
# Polygon Mainnet
POLYGON_MAINNET_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# OKX Web3 Wallet API (Onchain OS) — 多链资产/交易查询
# ────────────────────────────────────────────────────────────────────────────
# 从 https://web3.okx.com 开发者后台创建 API（前 3 项必填，否则余额/交易历史接口返回 503）
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# 可选：仅部分 project-scoped WaaS 接口需要
OKX_PROJECT_ID=

# ────────────────────────────────────────────────────────────────────────────
# Bridgers Cross-Chain Swap API — 代币兑换 (Swap)
# ────────────────────────────────────────────────────────────────────────────
# 与 Bridgers 协商获得的平台标识符（必填）
BRIDGERS_SOURCE_FLAG=

# ────────────────────────────────────────────────────────────────────────────
# 测试网 RPC 端点（可选）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Sepolia
ETH_SEPOLIA_RPC_URL=
# Base Sepolia
BASE_SEPOLIA_RPC_URL=

# ────────────────────────────────────────────────────────────────────────────
# ERC-4337 Bundler 端点（账户抽象）
# ────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
BUNDLER_URL_ETH=
# Base Mainnet
BUNDLER_URL_BASE=
# Arbitrum One
BUNDLER_URL_ARB=
# Optimism Mainnet
BUNDLER_URL_OP=
# BSC Mainnet
BUNDLER_URL_BSC=
# Ethereum Sepolia
BUNDLER_URL_ETH_SEPOLIA=
# Base Sepolia
BUNDLER_URL_BASE_SEPOLIA=

# ────────────────────────────────────────────────────────────────────────────
# NATS 消息队列
# ────────────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ────────────────────────────────────────────────────────────────────────────
# Redis 缓存
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ────────────────────────────────────────────────────────────────────────────
# DeepSeek AI API
# ────────────────────────────────────────────────────────────────────────────
# 从 https://platform.deepseek.com 获取 API KEY
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# 可选：自定义 base URL（默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：模型名称（默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-v4-flash

# ────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (FCM) — 推送通知
# ────────────────────────────────────────────────────────────────────────────
# FCM HTTP v1 API（legacy server key 已于 2024-06 被 Google 停用）。
# 从 Firebase Console > 项目设置 > 服务账号 > 生成新私钥 下载 service account JSON，
# 将其路径填在这里。project_id 从该 JSON 内读取，无需单独配置。
# 未设置时回退到标准变量 GOOGLE_APPLICATION_CREDENTIALS。
FCM_SERVICE_ACCOUNT_PATH=/path/to/cowallet-prod-firebase-adminsdk.json

# ────────────────────────────────────────────────────────────────────────────
# CORS 跨域配置
# ────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ────────────────────────────────────────────────────────────────────────────
# JWT 认证密钥
# ────────────────────────────────────────────────────────────────────────────
# 用于签发和验证用户登录令牌
# 生成强密钥：openssl rand -base64 32
# ⚠️  生产环境务必使用强密钥（最少 32 字符）
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# ────────────────────────────────────────────────────────────────────────────
# MPC 消息 HMAC 密钥（独立于 JWT_SECRET）
# ────────────────────────────────────────────────────────────────────────────
# 用于校验发往服务器参与方(Party 1)的 MPC 协议消息完整性
# 生成强密钥：openssl rand -base64 32
# ⚠️  必须独立于 JWT_SECRET；生产环境务必使用强密钥（最少 32 字符）
MPC_HMAC_KEY=change_me_independent_32_byte_min_hmac_key

# ────────────────────────────────────────────────────────────────────────────
# 分片加密密钥（32 字节 hex，用于加密 MPC 密钥分片）
# ────────────────────────────────────────────────────────────────────────────
# 生成：openssl rand -hex 32
# ⚠️  生产环境务必使用随机生成的密钥
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ────────────────────────────────────────────────────────────────────────────
# 运行环境
# ────────────────────────────────────────────────────────────────────────────
# 设为 production 时启用生产安全策略(例如未配置 TURNSTILE_SECRET_KEY 时
# 人机验证将 fail-closed 拒绝而非跳过)。本地/测试留空即可。
APP_ENV=

# ────────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile 人机验证
# ────────────────────────────────────────────────────────────────────────────
# 未配置时:非生产环境跳过校验;生产环境(APP_ENV=production)直接拒绝。
TURNSTILE_SECRET_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 日志级别
# ────────────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ────────────────────────────────────────────────────────────────────────────
# PostgreSQL 初始化密码（仅 Docker 第一次运行）
# ⚠️  生产环境务必修改为强密码
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=cowallet
